{
  "info": {
    "name": "Email Lists — Phase D",
    "description": "9 endpoints for Email List management (Phase D). Base URL: http://localhost:3001. Auth: dev_token_13 (admin bypass).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001", "type": "string" },
    { "key": "token", "value": "dev_token_13", "type": "string" },
    { "key": "list_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Lists CRUD",
      "item": [
        {
          "name": "1. Get All Email Lists",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/email-lists?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "", "disabled": true }
              ]
            },
            "description": "GET /api/email-lists — Lấy danh sách tất cả lists với pagination. Thêm ?search=beta để tìm theo tên."
          }
        },
        {
          "name": "2. Create Email List",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Beta Testers Q1 2026\",\n  \"description\": \"Danh sách user thử nghiệm tính năng mới\",\n  \"tags\": [\"beta\", \"q1\", \"2026\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/email-lists",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists"]
            },
            "description": "POST /api/email-lists — Tạo list mới. Trả về list vừa tạo kèm member_count=0."
          }
        },
        {
          "name": "3. Get Email List by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}"]
            },
            "description": "GET /api/email-lists/:id — Chi tiết 1 list kèm member_count hiện tại."
          }
        },
        {
          "name": "4. Update Email List",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Beta Testers Q1 2026 — Updated\",\n  \"description\": \"Mô tả đã cập nhật\",\n  \"tags\": [\"beta\", \"updated\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}"]
            },
            "description": "PUT /api/email-lists/:id — Cập nhật name/description/tags. Tất cả fields đều optional."
          }
        },
        {
          "name": "5. Delete Email List",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}"]
            },
            "description": "DELETE /api/email-lists/:id — Xóa list và toàn bộ members (cascade). Không thể hoàn tác."
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "6. Get List Members",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}/members?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}", "members"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "q", "value": "", "disabled": true, "description": "Search theo email" }
              ]
            },
            "description": "GET /api/email-lists/:id/members — Danh sách members với pagination. Thêm ?q=gmail.com để search theo email."
          }
        },
        {
          "name": "7. Add Members — by user_ids",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_ids\": [1, 2, 3]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}/members",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}", "members"]
            },
            "description": "POST /api/email-lists/:id/members — Thêm members bằng user_ids. Tự động resolve sang email từ bảng users. Duplicate bị bỏ qua."
          }
        },
        {
          "name": "7b. Add Members — by emails (external)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emails\": [\"external1@gmail.com\", \"external2@company.com\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}/members",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}", "members"]
            },
            "description": "POST /api/email-lists/:id/members — Thêm members bằng raw email (kể cả email ngoài hệ thống). user_id sẽ là null."
          }
        },
        {
          "name": "7c. Add Members — mixed (user_ids + emails)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_ids\": [4, 5],\n  \"emails\": [\"partner@external.com\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}/members",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}", "members"]
            },
            "description": "POST /api/email-lists/:id/members — Kết hợp cả user_ids và emails trong 1 request."
          }
        },
        {
          "name": "8. Remove Members — by emails",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emails\": [\"external1@gmail.com\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}/members",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}", "members"]
            },
            "description": "DELETE /api/email-lists/:id/members — Xóa members bằng email."
          }
        },
        {
          "name": "8b. Remove Members — by user_ids",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_ids\": [1, 2]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/email-lists/{{list_id}}/members",
              "host": ["{{base_url}}"],
              "path": ["api", "email-lists", "{{list_id}}", "members"]
            },
            "description": "DELETE /api/email-lists/:id/members — Xóa members bằng user_ids."
          }
        }
      ]
    },
    {
      "name": "Send Email with list_id",
      "item": [
        {
          "name": "9a. Send to Email List",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"list_id\": 1,\n  \"subject\": \"[InCard] Thông báo đến Beta Testers\",\n  \"body\": \"<h1>Xin chào!</h1><p>Đây là email gửi đến toàn bộ members trong list.</p>\",\n  \"campaign_name\": \"Beta Newsletter - 2026-03-13\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/emails/send",
              "host": ["{{base_url}}"],
              "path": ["api", "emails", "send"]
            },
            "description": "POST /api/emails/send với list_id — Gửi cho toàn bộ members trong Email List #1."
          }
        },
        {
          "name": "9b. Send to Email List + is_can_test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"list_id\": 1,\n  \"is_can_test\": true,\n  \"subject\": \"[TEST] Thông báo Beta Testers\",\n  \"body\": \"<h1>Test Email</h1><p>Chỉ gửi cho test users trong list.</p>\",\n  \"campaign_name\": \"[TEST] Beta Newsletter - 2026-03-13\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/emails/send",
              "host": ["{{base_url}}"],
              "path": ["api", "emails", "send"]
            },
            "description": "POST /api/emails/send với list_id + is_can_test — Chỉ gửi cho members trong list có is_can_test=1."
          }
        },
        {
          "name": "9c. Send to All + is_can_test only",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_can_test\": true,\n  \"subject\": \"[TEST] Broadcast to Test Users\",\n  \"body\": \"<p>Chỉ gửi cho tất cả users có is_can_test=1 trong hệ thống.</p>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/emails/send",
              "host": ["{{base_url}}"],
              "path": ["api", "emails", "send"]
            },
            "description": "POST /api/emails/send với is_can_test=true — Gửi cho tất cả users có is_can_test=1 (không giới hạn list)."
          }
        }
      ]
    }
  ]
}
